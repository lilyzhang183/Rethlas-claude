{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VerificationOutput",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "verification_report",
    "verdict",
    "repair_hints"
  ],
  "properties": {
    "verification_report": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "critical_errors",
        "gaps",
        "warnings"
      ],
      "properties": {
        "summary": {
          "type": "string"
        },
        "critical_errors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/finding"
          },
          "description": "Mathematical invalidity or wrong references. Block verdict=correct."
        },
        "gaps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/finding"
          },
          "description": "Proof may be true but missing a needed argument. Block verdict=correct."
        },
        "warnings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/finding"
          },
          "description": "Style, cleanup, orphan notation, redundant declarations, stale memory. Do NOT block verdict=correct."
        },
        "notes": {
          "type": "string",
          "description": "Free-form notes from the verifier, optional."
        }
      }
    },
    "verdict": {
      "type": "string",
      "enum": [
        "correct",
        "wrong"
      ]
    },
    "repair_hints": {
      "type": "string"
    }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "location",
        "issue"
      ],
      "properties": {
        "location": {
          "type": "string",
          "minLength": 1
        },
        "issue": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "type": "string",
          "enum": [
            "critical_error",
            "gap",
            "warning"
          ]
        },
        "evidence": {
          "type": "string"
        }
      }
    }
  }
}
